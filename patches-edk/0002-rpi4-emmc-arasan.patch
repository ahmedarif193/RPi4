+EFI_STATUS
+MMCSetIos (
+  IN EFI_MMC_HOST_PROTOCOL    *This,
+  IN UINT32                   BusClockFreq,
+  IN UINT32                   BusWidth,
+  IN UINT32                   TimingMode
+  )
+{
+  EFI_STATUS Status;
+  UINTN      ActualFrequency = 0;
+  UINT32     Divisor = 0;
+
+  if ((TimingMode == EMMCHS52DDR1V8) || (TimingMode == EMMCHS52DDR1V2)) {
+    DEBUG ((DEBUG_INFO, "ArasanMMCHost: MMCSetIos(): DDR mode %u not supported, falling back to SDR\n", TimingMode));
+    return EFI_UNSUPPORTED;
+  }
+
+  if (BusClockFreq != 0) {
+    Status = CalculateClockFrequencyDivisor (BusClockFreq, &Divisor, &ActualFrequency);
+    if (EFI_ERROR (Status)) {
+      DEBUG ((DEBUG_ERROR, "ArasanMMCHost: MMCSetIos(): Fail to set clock to %u Hz: %r\n", BusClockFreq, Status));
+      return Status;
+    }
+
+    SdMmioAnd32 (MMCHS_SYSCTL, ~CEN);
+  }
+
+  if (BusWidth == 8) {
+    SdMmioAndThenOr32 (MMCHS_HCTL, (UINT32) ~DTW_4_BIT, DTW_8_BIT);
+  } else if (BusWidth == 4) {
+    SdMmioAndThenOr32 (MMCHS_HCTL, (UINT32) ~DTW_8_BIT, DTW_4_BIT);
+  } else if (BusWidth == 1) {
+    SdMmioAnd32 (MMCHS_HCTL, (UINT32) ~(DTW_8_BIT | DTW_4_BIT));
+  }
+
+  if (BusClockFreq != 0) {
+    if (TimingMode != EMMCBACKWARD) {
+      SdMmioOr32 (MMCHS_HCTL, HSEN);
+    } else {
+      SdMmioAnd32 (MMCHS_HCTL, (UINT32) ~HSEN);
+    }
+
+    SdMmioOr32 (MMCHS_SYSCTL, ICE);
+    SdMmioAndThenOr32 (MMCHS_SYSCTL, (UINT32) ~CLKD_MASK, Divisor);
+    while ((MmioRead32 (MMCHS_SYSCTL) & ICS_MASK) != ICS);
+    SdMmioOr32 (MMCHS_SYSCTL, CEN);
+  }
+
+  DEBUG ((DEBUG_INFO,
+    "ArasanMMCHost: MMCSetIos() applied: ReqClock %u Hz ActualClock %lu Hz, BusWidth %u-bit, Timing 0x%x, HighSpeed %a\n",
+    BusClockFreq, (UINT64) ActualFrequency, BusWidth, TimingMode,
+    ((BusClockFreq != 0) && (TimingMode != EMMCBACKWARD)) ? "ON" : "OFF"));
+
   return EFI_SUCCESS;
 }
 
